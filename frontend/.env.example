# ==============================================================================
# FinTrack Frontend - Environment Template
# ==============================================================================
# Copy this file to `.env` and fill in real values for your local environment.
# Never commit `.env`. This template (`.env.example`) IS committed.
#
# Only variables prefixed with VITE_ are exposed to client code via
# `import.meta.env`. Any non-VITE_ variable will be inaccessible at runtime.
# ==============================================================================

# --- API ---
# Base URL of the backend API, including the `/api` global prefix.
# Examples:
#   Local dev:  http://localhost:3000/api
#   Staging:    https://api.staging.fintrack.example.com/api
VITE_API_URL=http://localhost:3000/api

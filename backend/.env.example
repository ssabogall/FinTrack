# ==============================================================================
# FinTrack Backend - Environment Template
# ==============================================================================
# Copy this file to `.env` and fill in real values for your local environment.
# Never commit `.env`. This template (`.env.example`) IS committed.
# ==============================================================================

# --- Server ---
# Port where Nest will listen.
PORT=3000

# --- CORS ---
# Origin of the frontend (no trailing slash). Must match the Vite dev server URL.
FRONTEND_ORIGIN=http://localhost:5173

# --- Database (SQLite) ---
# Path to the SQLite file, relative to the backend root.
DATABASE_PATH=database.sqlite

# --- Authentication (JWT) ---
# Secret used to sign access tokens. Use a long, random string in any
# non-local environment. NEVER reuse the local value in staging/production.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
# Token lifetime. Accepts the `ms` library format: `60s`, `15m`, `1h`, `7d`.
JWT_EXPIRES_IN=1h
